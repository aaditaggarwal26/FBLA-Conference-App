{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build Android release APK",
			"type": "shell",
			"command": "flutter",
			"args": [
				"build",
				"apk",
				"--release"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Build iOS release no-codesign",
			"type": "shell",
			"command": "flutter",
			"args": [
				"build",
				"ios",
				"--release",
				"--no-codesign"
			],
			"isBackground": false,
			"group": "build"
		}
	]
}