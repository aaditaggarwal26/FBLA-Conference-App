rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }
    
    function isOrganizer() {
      return isSignedIn() && (getUserRole() == 'organizer' || getUserRole() == 'admin');
    }
    
    // Users collection
    match /users/{userId} {
      // Anyone can read user profiles (for displaying names, photos in app)
      allow read: if isSignedIn();
      
      // Users can create their own profile
      allow create: if isSignedIn() && isOwner(userId);
      
      // Users can update their own profile, admins can update any profile
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      
      // Only admins can delete users
      allow delete: if isAdmin();
    }
    
    // Events collection
    match /events/{eventId} {
      // Anyone signed in can read events
      allow read: if isSignedIn();
      
      // Only organizers and admins can create/update/delete events
      allow create, update, delete: if isOrganizer();
    }
    
    // Announcements collection
    match /announcements/{announcementId} {
      // Anyone signed in can read announcements
      allow read: if isSignedIn();
      
      // Only organizers and admins can create/update/delete announcements
      allow create, update, delete: if isOrganizer();
    }
    
    // Resources collection
    match /resources/{resourceId} {
      // Anyone signed in can read resources
      allow read: if isSignedIn();
      
      // Only organizers and admins can manage resources
      allow create, update, delete: if isOrganizer();
    }
    
    // Speakers collection
    match /speakers/{speakerId} {
      // Anyone signed in can read speaker info
      allow read: if isSignedIn();
      
      // Only organizers and admins can manage speakers
      allow create, update, delete: if isOrganizer();
    }
    
    // Pin Trading collection
    match /pins/{pinId} {
      // Anyone signed in can read pins
      allow read: if isSignedIn();
      
      // Users can create their own pins
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Users can update/delete their own pins, admins can update/delete any pin
      allow update, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }
    
    // Chat Rooms collection
    match /chatRooms/{chatRoomId} {
      // Users can read chat rooms they're part of
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      // Users can create chat rooms if they're one of the participants
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      
      // Users can update chat rooms they're part of (for marking messages as read)
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      // Users can delete chat rooms they're part of
      allow delete: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      // Messages subcollection
      match /messages/{messageId} {
        // Users can read messages in chat rooms they're part of
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data.participants;
        
        // Users can create messages if they're the sender and part of the chat
        allow create: if isSignedIn() && 
          request.resource.data.senderId == request.auth.uid &&
          request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data.participants;
        
        // Only the sender can update/delete their own messages
        allow update, delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
      }
    }
  }
}
