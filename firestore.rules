rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    

    // Core helpers

    function isSignedIn() { return request.auth != null; }

    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    function hasPermission(permission) {

      return isAdmin() && (get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin' ||

                           permission in get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.permissions);

    }

    

    // School helpers (reusable)

    function getUserSchoolIds() {

      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;

      return 'schoolIds' in userData ? userData.schoolIds : 

             ('schoolId' in userData && userData.schoolId != null ? [userData.schoolId] : []);

    }

    function isSchoolAdmin(schoolId) {

      let school = get(/databases/$(database)/documents/schools/$(schoolId));

      return isSignedIn() && (school.data.ownerId == request.auth.uid || request.auth.uid in school.data.adminIds);

    }

    function isSchoolMember(schoolId) {

      return isSignedIn() && schoolId in getUserSchoolIds();

    }

    

    // Users

    match /users/{userId} {

      allow read: if isSignedIn();

      allow create: if isSignedIn() && isOwner(userId);

      allow update: if isSignedIn() && (isOwner(userId) || isAdmin() || 

                   request.resource.data.diff(resource.data).affectedKeys().hasOnly(['schoolId', 'schoolIds', 'schoolRole', 'isSchoolOwner']));

      allow delete: if isAdmin();

      // Social media connections (LinkedIn, etc.)
      match /socialMedia/{socialMediaId} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }

    }

    

    // Admins

    match /admins/{adminId} {

      allow read: if isSignedIn();

      allow create, update, delete: if hasPermission('manage_users');

    }

    

    // Admin-managed collections

    match /events/{eventId} {

      allow read: if isSignedIn();

      allow create, update, delete: if hasPermission('manage_events');

    }

    match /announcements/{announcementId} {

      allow read: if isSignedIn();

      allow create, update, delete: if hasPermission('manage_announcements');

    }

    match /schedules/{scheduleId} {

      allow read: if isSignedIn();

      allow create, update, delete: if hasPermission('manage_schedule');

    }

    match /resources/{resourceId} {

      allow read: if isSignedIn();

      allow create, update, delete: if isAdmin();

    }

    

    // User-owned collections

    match /pins/{pinId} {

      allow read: if isSignedIn();

      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || hasPermission('manage_pins'));

    }

    match /test_results/{resultId} {

      allow read, update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

    }

    

    // Chat

    match /chatRooms/{chatRoomId} {

      allow read, create, update: if isSignedIn();

      allow delete: if isSignedIn() || isAdmin();

      match /messages/{messageId} {

        allow read: if isSignedIn();

        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;

        allow update, delete: if isSignedIn() && (resource.data.senderId == request.auth.uid || isAdmin());

      }

    }

    

    // Schools

    match /schools/{schoolId} {

      function isOwner() { return isSignedIn() && resource.data.ownerId == request.auth.uid; }

      function isAdmin() { return isSignedIn() && request.auth.uid in resource.data.adminIds; }

      function isMember() { return isSignedIn() && (request.auth.uid in resource.data.memberIds || request.auth.uid in resource.data.adminIds); }

      function canManage() { return isOwner() || isAdmin(); }

      function isLeavingSchool() {
        // Allow if user is removing themselves from memberIds or adminIds
        let oldMemberIds = 'memberIds' in resource.data ? resource.data.memberIds : [];
        let newMemberIds = 'memberIds' in request.resource.data ? request.resource.data.memberIds : [];
        let oldAdminIds = 'adminIds' in resource.data ? resource.data.adminIds : [];
        let newAdminIds = 'adminIds' in request.resource.data ? request.resource.data.adminIds : [];
        
        let removedFromMembers = request.auth.uid in oldMemberIds && !(request.auth.uid in newMemberIds);
        let removedFromAdmins = request.auth.uid in oldAdminIds && !(request.auth.uid in newAdminIds);
        
        // Check that only memberIds/adminIds changed and user is removing themselves
        let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
        let onlyMemberFieldsChanged = affectedKeys.hasOnly(['memberIds', 'adminIds']);
        
        return isMember() && onlyMemberFieldsChanged && (removedFromMembers || removedFromAdmins);
      }

      

      allow read: if isSignedIn();

      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || request.auth.uid in resource.data.adminIds || isLeavingSchool());

      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      

      match /announcements/{announcementId} {

        allow read: if isSignedIn() && (isOwner() || isAdmin() || request.auth.uid in resource.data.memberIds);

        allow create, update, delete: if canManage();

      }

      match /resources/{resourceId} {

        allow read: if isSignedIn() && (isOwner() || isAdmin() || request.auth.uid in resource.data.memberIds);

        allow create, update, delete: if canManage();

      }

      // Social media connections (LinkedIn, etc.) for schools
      match /socialMedia/{socialMediaId} {
        allow read: if isSignedIn() && (isOwner() || isAdmin() || isMember());
        allow write: if isSignedIn() && canManage();
      }

    }

    

    // School-scoped collections (top-level for queries)

    match /school_announcements/{announcementId} {

      allow read: if isSignedIn() && isSchoolMember(resource.data.schoolId);

      allow create: if isSignedIn() && isSchoolAdmin(request.resource.data.schoolId);

      allow update, delete: if isSignedIn() && isSchoolAdmin(resource.data.schoolId);

    }

    match /school_resources/{resourceId} {

      allow read: if isSignedIn() && isSchoolMember(resource.data.schoolId);

      allow create: if isSignedIn() && isSchoolAdmin(request.resource.data.schoolId);

      allow update, delete: if isSignedIn() && isSchoolAdmin(resource.data.schoolId);

    }

    match /school_events/{eventId} {

      allow read: if isSignedIn() && isSchoolMember(resource.data.schoolId);

      allow create: if isSignedIn() && isSchoolAdmin(request.resource.data.schoolId);

      allow delete: if isSignedIn() && isSchoolAdmin(resource.data.schoolId);

      allow update: if isSignedIn() && (isSchoolAdmin(resource.data.schoolId) ||

                   (isSchoolMember(resource.data.schoolId) && 

                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attendeeIds'])));

    }

    match /parsed_events/{eventId} {

      allow read: if isSignedIn() && isSchoolMember(resource.data.schoolId);

      allow create: if isSignedIn() && isSchoolAdmin(request.resource.data.schoolId);

      allow delete: if isSignedIn() && isSchoolAdmin(resource.data.schoolId);

      allow update: if isSignedIn() && (isSchoolAdmin(resource.data.schoolId) ||

                   (isSchoolMember(resource.data.schoolId) && 

                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notifyUsers'])));

    }

    match /location_pins/{pinId} {

      allow read: if isSignedIn();

      allow create: if isSignedIn() && isSchoolMember(request.resource.data.schoolId);

      allow update, delete: if isSignedIn() && isSchoolAdmin(resource.data.schoolId);

    }

    match /event_location_links/{eventKey} {

      allow read: if isSignedIn();

      allow create: if isSignedIn() && isSchoolMember(request.resource.data.schoolId);

      allow update: if isSignedIn() && isSchoolMember(resource.data.schoolId);

      allow delete: if isSignedIn() && isSchoolAdmin(resource.data.schoolId);

    }

    

    // Join requests

    match /school_join_requests/{requestId} {

      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || 

                 isSchoolAdmin(resource.data.schoolId));

      allow update: if isSignedIn() && isSchoolAdmin(resource.data.schoolId);

      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || 

                 isSchoolAdmin(resource.data.schoolId));

    }

  }

}
