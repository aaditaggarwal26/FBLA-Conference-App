rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    function getUserRole() {
      return isSignedIn() ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : '';
    }
    
    function isSuperAdmin() {
      return getUserRole() == 'super_admin';
    }
    
    function isSchoolAdmin() {
      return getUserRole() == 'school_admin';
    }
    
    function hasPermission(permission) {
      return isAdmin() && 
        (get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin' ||
         permission in get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.permissions);
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin() || isSuperAdmin());
      allow delete: if isAdmin() || isSuperAdmin();
    }
    
    // Schools collection
    match /schools/{schoolId} {
      allow read: if isSignedIn();
      // Allow any signed-in user to create a school (they become admin automatically)
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.adminIds;
      allow update: if isSignedIn() && 
        (request.auth.uid in resource.data.adminIds || isSuperAdmin());
      allow delete: if isSignedIn() && 
        (request.auth.uid in resource.data.adminIds || isSuperAdmin());
    }
    
    // School messages
    match /school_messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == resource.data.senderId;
      allow delete: if isSignedIn() && 
        (request.auth.uid == resource.data.senderId || isSuperAdmin());
    }
    
    // Admins collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow create, update, delete: if hasPermission('manage_users') || isSuperAdmin();
    }
    
    // Events collection
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if hasPermission('manage_events') || isSchoolAdmin() || isSuperAdmin();
      allow update: if hasPermission('manage_events') || isSchoolAdmin() || isSuperAdmin();
      allow delete: if hasPermission('manage_events') || isSuperAdmin();
    }
    
    // Announcements collection
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create: if hasPermission('manage_announcements') || isSchoolAdmin() || isSuperAdmin();
      allow update: if hasPermission('manage_announcements') || isSchoolAdmin() || isSuperAdmin();
      allow delete: if hasPermission('manage_announcements') || isSuperAdmin();
    }
    
    // Schedule collection
    match /schedules/{scheduleId} {
      allow read: if isSignedIn();
      allow create: if hasPermission('manage_schedule') || isSuperAdmin();
      allow update: if hasPermission('manage_schedule') || isSuperAdmin();
      allow delete: if hasPermission('manage_schedule') || isSuperAdmin();
    }
    
    // Pin Trading collection
    match /pins/{pinId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        hasPermission('manage_pins') || isSuperAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        hasPermission('manage_pins') || isSuperAdmin()
      );
    }
    
    // Chat Rooms collection
    match /chatRooms/{chatRoomId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() || isAdmin() || isSuperAdmin();
      
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isSignedIn() && 
          (resource.data.senderId == request.auth.uid || isAdmin() || isSuperAdmin());
      }
    }
    
    // Resources collection
    match /resources/{resourceId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isSuperAdmin();
    }
    
    // School Events collection
    match /school_events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.auth.uid in get(/databases/$(database)/documents/schools/$(request.resource.data.schoolId)).data.adminIds || 
        isSuperAdmin()
      );
      allow update, delete: if isSignedIn() && (
        request.auth.uid in get(/databases/$(database)/documents/schools/$(resource.data.schoolId)).data.adminIds || 
        isSuperAdmin()
      );
    }
    
    // School Resources collection
    match /school_resources/{resourceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.auth.uid in get(/databases/$(database)/documents/schools/$(request.resource.data.schoolId)).data.adminIds || 
        isSuperAdmin()
      );
      allow update, delete: if isSignedIn() && (
        request.auth.uid in get(/databases/$(database)/documents/schools/$(resource.data.schoolId)).data.adminIds || 
        isSuperAdmin()
      );
    }
  }
}